        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cair no domingo"
          }
        }
      }
    },
    "If the period start date falls on a weekend, PiggyPulse can shift it to the nearest weekday. This only affects when a period is recorded as starting — it does not change how long the period lasts.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se a data de início do período cair em um fim de semana, o PiggyPulse pode movê-la para o dia útil mais próximo. Isso afeta apenas quando o período é registrado como iniciado — não altera a duração do período."
          }
        }
      }
    },
